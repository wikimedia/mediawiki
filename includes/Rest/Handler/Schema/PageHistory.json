			"format": "uri",
			"x-i18n-description": "rest-property-desc-revision-url-older",
			"example": "https://en.wikipedia.org/w/rest.php/v1/page/Solar_System/history?older_than=1218700625"
		},
		"newer": {
			"type": "string",
			"format": "uri",
			"x-i18n-description": "rest-property-desc-revision-url-newer",
			"example": "https://en.wikipedia.org/w/rest.php/v1/page/Solar_System/history?newer_than=1256949142"
