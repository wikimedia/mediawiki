{
	"x-i18n-description": "rest-schema-desc-revision-metadata",
	"required": [
		"timestamp"
	],
	"properties": {
		"id": {
			"type": "integer",
			"x-i18n-description": "rest-param-desc-revision-id",
			"example": 1334073939
		},
		"size": {
			"type": "integer",
			"x-i18n-description": "rest-property-desc-revision-size",
			"example": 238224
		},
		"delta": {
			"type": "integer",
			"nullable": true,
			"x-i18n-description": "rest-property-desc-revision-delta",
			"example": 25
		},
		"comment": {
			"type": "string",
			"nullable": true,
			"x-i18n-description": "rest-property-desc-revision-comment",
			"example": "Added isbn. Normalized parameter names."
		},
		"minor": {
			"type": "boolean",
			"x-i18n-description": "rest-property-desc-revision-minor",
			"example": false
		},
		"timestamp": {
			"type": "string",
			"format": "date-time",
			"x-i18n-description": "rest-property-desc-revision-timestamp",
			"example": "2026-01-21T10:50:43Z"
		},
		"content_model": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-revision-content-model",
			"example": "wikitext"
		},
		"page": {
			"x-i18n-description": "rest-property-desc-revision-page",
			"required": [
				"id",
				"key",
				"title"
			],
			"properties": {
				"id": {
					"type": "integer",
					"x-i18n-description": "rest-property-desc-page-id",
					"example": 26903
				},
				"key": {
					"type": "string",
					"x-i18n-description": "rest-property-desc-page-key",
					"example": "Solar_System"
				},
				"title": {
					"type": "string",
					"x-i18n-description": "rest-property-desc-page-title",
					"example": "Solar System"
				}
			}
		},
		"license": {
			"type": "object",
			"x-i18n-description": "rest-property-desc-page-license",
			"required": [
				"url",
				"title"
			],
			"properties": {
				"url": {
					"type": "string",
					"x-i18n-description": "rest-property-desc-page-license-url-html",
					"example": "https://creativecommons.org/licenses/by-sa/4.0/deed.en"
				},
				"title": {
					"type": "string",
					"x-i18n-description": "rest-property-desc-page-license-title-html",
					"example": "Creative Commons Attribution-Share Alike 4.0"
				}
			}
		},
		"user": {
			"type": "object",
			"x-i18n-description": "rest-property-desc-user",
			"nullable": true,
			"required": [
				"id",
				"name"
			],
			"properties": {
				"id": {
					"type": "integer",
					"x-i18n-description": "rest-property-desc-user-id",
					"example": 7903804
				},
				"name": {
					"type": "string",
					"x-i18n-description": "rest-property-desc-user-name",
					"example": "Citation bot"
				}
			}
		},
		"html_url": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-revision-html-url",
			"example": "https://en.wikipedia.org/w/rest.php/v1/revision/1334073939/html"
		},
		"html": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"title": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-revision-title"
		},
		"page_id": {
			"type": "integer",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"rev": {
			"type": "integer",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"tid": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"namespace": {
			"type": "integer",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"user_id": {
			"type": "integer",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"user_text": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"tags": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"restrictions": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"page_language": {
			"type": "string",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		},
		"redirect": {
			"type": "boolean",
			"x-i18n-description": "rest-property-desc-page-restbase-compatibility"
		}
	}
}
